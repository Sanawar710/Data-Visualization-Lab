              <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Teenagers with higher daily social media usage tend to report significantly higher anxiety and stress levels.' captured-sheet='Sheet 1' id='1' />
                  <story-point caption='While usage varies, certain platforms show a higher tendency toward addiction, especially among female users.' captured-sheet='Sheet 2' id='2' />
                  <story-point caption='Excessive screen time before sleep is a primary driver for reduced sleep hours, which directly impacts academic performance.' captured-sheet='Sheet 3' id='3' />
                  <story-point caption='Use this interactive dashboard to explore how age, gender, and platform choice affect mental health metrics.' captured-sheet='Teen Mental Health &amp; Digital Habits Overview' id='4'>
                    <capturedDeltas>
                      <worksheet name='Sheet 2'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.0h07i0c1dho4oo129rlay1vks6ej].[avg:addiction_level:qk]' field-type='quantitative' max='12.109890434851698' min='-0.98753215353899415' range-type='fixed' scope='rows' type='space' />
                          </style-rule>
                        </style>
